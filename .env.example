# Atlas — variables d'environnement (compile-time via dart-define-from-file)
#
# 1. Copier le fichier correspondant à votre environnement :
#    cp .env.development.example .env.development
# 2. Remplir SUPABASE_URL et SUPABASE_ANON_KEY (clé anon publique uniquement).
# 3. Lancer l'app :
#    flutter run --dart-define-from-file=.env.development
#
# Ne jamais committer les fichiers .env.* réels.
# Ne jamais placer la clé service-role Supabase dans l'application Flutter.

ATLAS_ENV=development
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional crash reporting (private beta). Leave empty to disable.
SENTRY_DSN=
